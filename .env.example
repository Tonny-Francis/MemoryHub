# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://memoryhub:memoryhub@localhost:5432/memoryhub

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Initial admin (created on first start if no users exist) ──────────────────
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=changeme123
INITIAL_ADMIN_NAME=Admin

# ── Vault ─────────────────────────────────────────────────────────────────────
# Local path where the vault git repo is cloned / stored
VAULT_DIR=/data/vault

# Optional: remote git repo URL (with embedded token for push)
# Example: https://oauth2:glpat-TOKEN@gitlab.com/myorg/memoryhub-vault.git
GIT_VAULT_REPO_URL=

# How often to auto-pull from remote (ms). Default: 5 minutes
GIT_SYNC_INTERVAL_MS=300000

GIT_USER_NAME=MemoryHub
GIT_USER_EMAIL=memoryhub@localhost

# ── Ingestion — GitLab ────────────────────────────────────────────────────────
# GitLab instance URL (default: gitlab.com)
GITLAB_URL=https://gitlab.com
# GitLab application access token (read_api scope)
GITLAB_TOKEN=
# Shared secret for validating incoming webhooks from GitLab
GITLAB_WEBHOOK_SECRET=
# Comma-separated project IDs or paths to poll (e.g. "123,myorg/myrepo")
GITLAB_PROJECT_IDS=

# ── Ingestion — Discord ───────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
# Comma-separated channel IDs to monitor for decisions
DISCORD_CHANNEL_IDS=
# Voice recording (optional)
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=

# ── Ingestion — Trello ────────────────────────────────────────────────────────
TRELLO_API_KEY=
TRELLO_TOKEN=
# Comma-separated board IDs to monitor
TRELLO_BOARD_IDS=

# ── AI (optional) ─────────────────────────────────────────────────────────────
# Anthropic Claude Haiku — extrair decisões de MRs/commits/Discord
ANTHROPIC_API_KEY=
# OpenAI — busca semântica (pgvector embeddings) + transcrição de voz (Whisper)
OPENAI_API_KEY=

# ── Husky commit hook (no projeto alvo, não aqui) ─────────────────────────────
# MEMORYHUB_API_URL=https://memoryhub.empresa.com
# MEMORYHUB_API_TOKEN=<jwt de /api/auth/login>
# MEMORYHUB_PROJECT=slug-do-projeto
