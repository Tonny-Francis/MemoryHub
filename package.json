{
  "name": "memoryhub",
  "version": "0.1.0",
  "description": "Engineering knowledge base as MCP — multi-project second brain for software teams",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:ui": "cd ui && npm run build",
    "build:all": "npm run build:ui && npm run build",
    "start": "node dist/server.js",
    "ingestion:run": "node dist/ingestion-runner.js",
    "voice:record": "node dist/voice-recorder.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "project:init": "node scripts/memoryhub-init.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@discordjs/voice": "^0.19.2",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "discord.js": "^14.26.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "opusscript": "^0.0.8",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prism-media": "^1.3.5",
    "simple-git": "^3.27.0",
    "zod": "^3.24.2"
  },
  "overrides": {
    "cross-spawn": "^7.0.5",
    "glob": "^10.5.0",
    "minimatch": "^3.1.3",
    "tar": "^7.5.3",
    "undici": "^6.27.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.14.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
