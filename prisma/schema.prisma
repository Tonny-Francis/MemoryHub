generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(READER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  repoUrl     String?
  owner       String?
  stack       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model VaultEmbedding {
  id          String   @id @default(cuid())
  path        String   @unique
  projectSlug String
  content     String   @db.Text
  embedding   Unsupported("vector(1536)")?
  updatedAt   DateTime @updatedAt

  @@index([projectSlug])
  @@map("vault_embeddings")
}

enum Role {
  READER
  WRITER
  ADMIN
}
